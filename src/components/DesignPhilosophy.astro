<style>
  .design-card { position: relative; border-radius: 2rem; overflow: hidden; cursor: pointer; }
  .design-card img { width: 100%; height: 500px; object-fit: cover; opacity: 0.6; transition: opacity 1s, transform 1s; }
  .design-card:hover img { opacity: 0.8; transform: scale(1.05); }
  .design-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, var(--color-background) 0%, rgba(16,19,26,0.6) 50%, transparent 100%);
    display: flex; flex-direction: column; justify-content: flex-end; padding: 3rem;
  }
  .design-card h3 { transition: transform 0.5s; }
  .design-card:hover h3 { transform: translateY(-8px); }
  .design-card p { transition: transform 0.5s 75ms; }
  .design-card:hover p { transform: translateY(-8px); }
  .btn-view {
    width: fit-content; background: var(--color-primary); color: var(--color-on-primary);
    padding: 12px 32px; border-radius: 0.75rem; font-weight: 700; border: none; cursor: pointer;
    box-shadow: 0 10px 20px rgba(59,130,246,0.3); transition: transform 0.3s;
  }
  .btn-view:hover { transform: scale(1.05); }
</style>

<section class="py-section-padding-desktop reveal" style="background:var(--color-surface-container-lowest)">
  <div class="px-gutter max-w-container-max mx-auto">
    <h2 class="text-headline-lg" style="color:var(--color-on-surface);margin-bottom:3rem;text-align:center">Design Philosophy</h2>
    <div class="design-card glass-card" style="border:none">
      <img alt="UI/UX Case Study" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDJv3uHO_qimnBnLK9BGrQexdjirvNpWLsGN1U7L3iXcAwA5uJxOWHZs7Tgi5o7DX8oCS6eEa1JVrHastnkkHb-b1lYzsWoplGYwgYDbGPOuBA7-g9iLBhIpQSocrgfGWu35A8-frH0vfO_EeMH7dGiT7zWfxV1ZQMsMv8o_PK2JigZwj8vcjx_6sR2HIPz0W6psAu_TbMEdxgS6sm1tl5xEZQr47Cb0S0yykuvtjbxJOojJdc-cf93_mA3qtowv8kMNmdDW96EZGU" />
      <div class="design-overlay">
        <span class="text-label-sm" style="color:var(--color-primary);font-weight:700;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:1rem;display:block">Featured Case Study</span>
        <h3 class="text-headline-lg" style="color:var(--color-on-surface);margin-bottom:1.5rem">Next-Gen Fintech Experience</h3>
        <p class="text-body-lg" style="color:var(--color-on-surface-variant);max-width:42rem;margin-bottom:2rem">Exploring the intersection of complex financial data and minimalist user experience design.</p>
        <button class="btn-view">View full process</button>
      </div>
    </div>
  </div>
</section>
