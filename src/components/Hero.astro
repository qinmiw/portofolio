---
---
<style>
  .hero-section {
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: var(--spacing-section-padding-desktop);
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  .hero-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 768px) {
    .hero-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 767px) {
    .hero-section { padding-top: 5rem; padding-bottom: 4rem; }
    .hero-grid { text-align: center; }
    .hero-btns { justify-content: center; }
    .hero-socials { justify-content: center; }
    .hero-img-order { order: -1; }
    .profile-frame img { max-width: 220px; margin: 0 auto; }
  }
  .hero-badge {
    display: inline-block;
    background: rgba(0, 165, 114, 0.15);
    color: var(--color-secondary);
    padding: 4px 16px;
    border-radius: 9999px;
    border: 1px solid rgba(78,222,163,0.2);
    box-shadow: 0 0 10px rgba(78,222,163,0.1);
    margin-bottom: 1.5rem;
  }
  .btn-primary {
    background: var(--color-primary); color: var(--color-on-primary);
    padding: 14px 28px; border-radius: 0.75rem; font-weight: 700;
    text-decoration: none; box-shadow: 0 10px 20px rgba(59,130,246,0.3);
    transition: transform 0.3s, box-shadow 0.3s; display: inline-block;
  }
  .btn-primary:hover { transform: scale(1.05); box-shadow: 0 15px 30px rgba(59,130,246,0.4); }
  .btn-secondary-outline {
    background: var(--color-surface-container-high); color: var(--color-on-surface);
    padding: 14px 28px; border-radius: 0.75rem; font-weight: 700;
    text-decoration: none; border: 1px solid rgba(66,71,84,0.2);
    transition: background 0.3s, border-color 0.3s; display: inline-block;
  }
  .btn-secondary-outline:hover { background: var(--color-surface-container-highest); border-color: rgba(173,198,255,0.5); }
  .profile-glow {
    position: absolute; inset: -16px;
    background: linear-gradient(to top right, var(--color-primary), var(--color-secondary));
    opacity: 0.2; filter: blur(48px); transition: opacity 0.7s;
  }
  .profile-wrapper:hover .profile-glow { opacity: 0.5; }
  .profile-frame {
    position: relative; border-radius: 1.5rem; overflow: hidden;
    border: 2px solid rgba(173,198,255,0.3); padding: 8px;
    background: var(--color-surface-container-low);
    box-shadow: 0 25px 50px rgba(0,0,0,0.5); transition: border-color 0.5s;
  }
  .profile-wrapper:hover .profile-frame { border-color: rgba(173,198,255,0.6); }
  .profile-frame img { width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 1rem; filter: grayscale(1); transition: filter 0.7s; }
  .profile-frame img:hover { filter: grayscale(0); }
  .social-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    color: var(--color-on-surface-variant); text-decoration: none; font-weight: 600;
    padding: 8px 16px; border-radius: 0.75rem;
    border: 1px solid rgba(66,71,84,0.2);
    background: var(--color-surface-container-high);
    transition: color 0.3s, border-color 0.3s, background 0.3s;
  }
  .social-link:hover { color: var(--color-secondary); border-color: rgba(78,222,163,0.4); background: var(--color-surface-container-highest); }
</style>

<section class="hero-section px-gutter max-w-container-max mx-auto hero-grid">
  <canvas id="hero-canvas" style="position:absolute;inset:0;z-index:0;pointer-events:none;opacity:0.4"></canvas>

  <div style="position:relative;z-index:10" class="reveal">
    <span class="hero-badge text-label-sm">Full Stack Web &amp; Mobile Developer</span>
    <h2 style="color:var(--color-on-surface-variant);font-size:1.25rem;font-weight:600;margin-bottom:0.5rem">Hi, I'm Muhammad Qinthara Izzatullah</h2>
    <h1 class="text-headline-xl" style="color:var(--color-on-surface);margin-bottom:1.5rem">
      Building Modern Web & Mobile Experiences
    </h1>
    <p class="text-body-lg" style="color:var(--color-on-surface-variant);margin-bottom:2.5rem;max-width:32rem">
      Full Stack Web & Mobile Developer specializing in modern web applications, mobile apps, and backend systems. Passionate about building responsive, scalable, and user-focused digital experiences.
    </p>
    <div class="hero-btns" style="display:flex;flex-wrap:wrap;gap:1rem">
      <a class="btn-primary" href="#contact">Contact Me</a>
      <a class="btn-secondary-outline" href="#projects">View Projects</a>
    </div>
  </div>

  <div class="profile-wrapper hero-img-order reveal animate-float" style="position:relative;z-index:10;transition-delay:200ms">
    <div class="profile-glow"></div>
    <div class="profile-frame">
      <img alt="DevCommand Profile" src="public/potoporto.jpg" />
    </div>
  </div>
</section>
