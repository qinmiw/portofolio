---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Employee Attendance System | Project Showcase">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" rel="stylesheet" />
<style>
  body { background-color: #10131a; color: #e1e2ec; }
  .glass-card {
    background: rgba(30,41,59,0.5);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .glass-card:hover {
    border-color: #4d8eff;
    box-shadow: 0 20px 40px rgba(77,142,255,0.15);
    background: rgba(30,41,59,0.8);
  }
  .tech-chip {
    background: rgba(46,48,56,0.8);
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
  }
  .tech-chip.active-laravel { box-shadow: 0 0 15px rgba(255,45,32,0.4); border-color: rgba(255,45,32,0.5); }
  .tech-chip.active-mysql { box-shadow: 0 0 15px rgba(0,117,143,0.4); border-color: rgba(0,117,143,0.5); }
  .tech-chip.active-js { box-shadow: 0 0 15px rgba(250,204,21,0.4); border-color: rgba(250,204,21,0.5); }
  .bg-grid-pattern {
    background-image: linear-gradient(to right,rgba(255,255,255,0.02) 1px,transparent 1px), linear-gradient(to bottom,rgba(255,255,255,0.02) 1px,transparent 1px);
    background-size: 40px 40px;
  }
  .inner-highlight { box-shadow: inset 0 1px 0 rgba(255,255,255,0.1); }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }
  .animate-float { animation: float 6s ease-in-out infinite; }
  * { font-family: 'Inter', sans-serif; box-sizing: border-box; }
  .px-gutter { padding-left: 24px; padding-right: 24px; }
  .max-w-container { max-width: 1200px; margin: 0 auto; }
  .hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: center; }
  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: stretch; }
  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr; }
    .two-col { grid-template-columns: 1fr; }
    main { padding-top: 6rem !important; padding-bottom: 60px !important; }
    .hero-grid > div:first-child { order: 2; }
    .hero-grid > div:last-child { order: 1; }
  }
</style>

<div class="fixed inset-0 bg-grid-pattern z-[-1] pointer-events-none"></div>
<div class="fixed inset-0 pointer-events-none z-[-1]" style="background:radial-gradient(ellipse at top, rgba(77,142,255,0.1) 0%, #10131a 60%)"></div>

<!-- Navbar -->
<nav style="position:fixed;top:0;width:100%;z-index:50;background:rgba(16,19,26,0.5);backdrop-filter:blur(24px);border-bottom:1px solid rgba(140,144,159,0.1)">
  <div class="px-gutter max-w-container" style="display:flex;justify-content:space-between;align-items:center;padding-top:1rem;padding-bottom:1rem">
    <a href="/" style="font-size:30px;font-weight:700;color:#e1e2ec;text-decoration:none">Qinthara</a>
    <a href="/#projects" style="font-size:14px;font-weight:600;color:#adc6ff;text-decoration:none;display:flex;align-items:center;gap:6px">
      <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span> Back to Projects
    </a>
  </div>
</nav>

<main style="padding-top:8rem;padding-bottom:120px">
  <!-- Hero -->
  <section class="px-gutter max-w-container" style="margin-bottom:120px">
    <div class="hero-grid">
      <div style="position:relative">
        <div style="position:absolute;top:-5rem;left:-5rem;width:16rem;height:16rem;background:rgba(77,142,255,0.2);border-radius:9999px;filter:blur(100px);pointer-events:none"></div>
        <h1 style="font-size:clamp(2rem,5vw,60px);font-weight:800;line-height:1.1;letter-spacing:-0.02em;color:#e1e2ec;margin-bottom:1.5rem">
          Employee <span style="background:linear-gradient(to right,#4d8eff,#4edea3);-webkit-background-clip:text;-webkit-text-fill-color:transparent">Attendance System</span>
        </h1>
        <p style="font-size:18px;line-height:1.6;color:#c2c6d6;margin-bottom:2.5rem;max-width:36rem">
          Digital attendance system with face recognition, leave management, overtime requests, and automated PDF reporting for both Admin and Employee roles.
        </p>
      </div>
      <div style="position:relative">
        <div class="glass-card inner-highlight animate-float" style="border-radius:0.75rem;overflow:hidden;padding:8px">
          <img alt="Employee Attendance System" src="/absenpekerjaan.png" style="width:100%;height:auto;display:block;border-radius:0.5rem" />
        </div>
        <div style="position:absolute;inset:-1rem;background:linear-gradient(to top right,rgba(77,142,255,0.2),rgba(78,222,163,0.1));border-radius:1rem;filter:blur(32px);z-index:-1"></div>
      </div>
    </div>
  </section>

  <!-- Overview & Tech Stack -->
  <section class="px-gutter max-w-container two-col" style="margin-bottom:120px">
    <div class="glass-card inner-highlight" style="border-radius:0.75rem;padding:2rem">
      <h2 style="font-size:24px;font-weight:600;color:#e1e2ec;margin-bottom:1.5rem">Project Overview</h2>
      <p style="font-size:15px;line-height:1.7;color:#c2c6d6;margin-bottom:1rem">
        A digital employee attendance application with two roles: Admin and Employee. Employees can clock in using JavaScript-based face recognition, and submit leave, overtime, and sick day requests.
      </p>
      <p style="font-size:15px;line-height:1.7;color:#c2c6d6">
        Admins can manage employee data, review submissions, and view attendance recaps. The system also provides PDF report printing and weekly/monthly attendance summaries, making attendance monitoring faster, easier, and more accurate.
      </p>
    </div>
    <div class="glass-card inner-highlight" style="border-radius:0.75rem;padding:2rem">
      <h3 style="font-size:24px;font-weight:600;color:#e1e2ec;margin-bottom:1.5rem">Tech Stack</h3>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem">
        <div class="tech-chip active-js" style="border-radius:0.5rem;padding:1.5rem;display:flex;align-items:center;justify-content:center;cursor:pointer">
          <span style="font-size:16px;font-weight:600;color:#e1e2ec">JavaScript</span>
        </div>
        <div class="tech-chip active-laravel" style="border-radius:0.5rem;padding:1.5rem;display:flex;align-items:center;justify-content:center;cursor:pointer">
          <span style="font-size:16px;font-weight:600;color:#e1e2ec">Laravel</span>
        </div>
        <div class="tech-chip active-mysql" style="border-radius:0.5rem;padding:1.5rem;display:flex;align-items:center;justify-content:center;cursor:pointer">
          <span style="font-size:16px;font-weight:600;color:#e1e2ec">MySQL</span>
        </div>
        <div class="tech-chip" style="border-radius:0.5rem;padding:1.5rem;display:flex;align-items:center;justify-content:center;cursor:pointer">
          <span style="font-size:16px;font-weight:600;color:#e1e2ec">Face Recognition</span>
        </div>
      </div>
    </div>
  </section>
</main>

<!-- Footer -->
<footer style="border-top:1px solid rgba(66,71,84,0.1);background:#0b0e15">
  <div class="px-gutter max-w-container" style="display:flex;justify-content:space-between;align-items:center;padding-top:1.5rem;padding-bottom:1.5rem;flex-wrap:wrap;gap:1rem">
    <span style="font-size:30px;font-weight:800;color:#e1e2ec">Qinthara</span>
    <span style="font-size:14px;color:#c2c6d6">© 2026 Muhammad Qinthara Izzatullah. All rights reserved.</span>
    <div style="display:flex;gap:1.5rem">
      <a href="https://github.com/qinmiw" target="_blank" rel="noopener noreferrer" style="color:#c2c6d6;text-decoration:none;font-size:14px">GitHub</a>
      <a href="https://www.linkedin.com/in/muhammad-qinthara-izzatullah-7a82383a8/" target="_blank" rel="noopener noreferrer" style="color:#c2c6d6;text-decoration:none;font-size:14px">LinkedIn</a>
      <a href="mailto:qinthara260807@gmail.com" style="color:#c2c6d6;text-decoration:none;font-size:14px">Email</a>
    </div>
  </div>
</footer>
</Layout>
